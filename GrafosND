/*01. Lista de adjacência de grafos não direcionados*/
package grafos;
import java.util.*;
public class GrafosND {
	//cria um mapa chamado adjacencia que irá armazenar os vertices e arestas
	private Map<Integer, Set<Integer>> adjacencia; //"set" serve para não permitir duplicatas
	
	//construtor que inicializa o mapa
	public GrafosND() {
		// TODO Auto-generated constructor stub
		adjacencia = new HashMap<>();
	}
	
	public void adicionarVertices(int no) { 
		//a função adiciona o vertice à lista adjacente se o espaço estiver vazio
		//no é o identificador do vertice
		
		adjacencia.putIfAbsent(no, new HashSet<>());

		//HashSet<>() : constroi um novo conjunto vazio e serve para armazenar os vizinhos do vertice
		//o HashSet oferece um desempenho de tempo constante, o que é eficiente para ações de adição e verificação de vertices

	}

	public void adicionarAresta(int V1, int V2) {
		//onde V1 atua como origem e V2 como destino
		adicionarVertices(V1);			//inicializa o vertice
		adicionarVertices(V2);
		adjacencia.get(V1).add(V2);		//V1->V2
		adjacencia.get(V2).add(V1);		// V2->V1	
	}
	
	public void imprimir() {
		//percorre todo o vertice e imprime o vertice seguido da sua lista de adjacencia
       for (int vertice : adjacencia.keySet()) {
           System.out.println(vertice + " -> " + adjacencia.get(vertice));//adjacencia.get()serve para mostrar os 'vizinhos"
       }
	}
	
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		GrafosND grafo = new GrafosND();//inicializaçaõ do meu mapa vazio;
       grafo.adicionarAresta(1, 2);		//1->2 e 2-1
       grafo.adicionarAresta(1, 3);		//1-3 e 3-1
       grafo.adicionarAresta(2, 4);		//2-4 e 4-2
       grafo.imprimir();
       //a quantidade de vizinhos mostra o grau do vertice
	}
}
